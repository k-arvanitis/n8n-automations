    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.body.payload;\nconst payload = JSON.parse(raw);\nconst action = payload.actions[0].value;\n\nconst text = payload.message.text || '';\nconst dataLine = text.split(' — ')[1] || '';\nconst parts = dataLine.trim().split('|');\n\nreturn [{\n  json: {\n    action,\n    name: parts[0] || '',\n    email: parts[1] || '',\n    job_title: parts[2] || '',\n    company: parts[3] || '',\n    industry: parts[4] || '',\n    company_size: parts[5] || '',\n    ai_score: parseInt(parts[6]) || 0,\n    ai_grade: parts[7] || '',\n    ai_action: parts[8] || '',\n    ai_reason: parts[9] || '',\n    ai_signal: parts[10] || ''\n  }\n}];"
      },
