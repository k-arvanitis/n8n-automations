    },
    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "gpt-4.1-mini",
          "mode": "list",
          "cachedResultName": "GPT-4.1-MINI"
        },
        "messages": {
          "values": [
            {
              "content": "You are a senior sales qualification AI for a B2B SaaS company. Your ideal customer profile (ICP) is: companies with 50-500 employees, SaaS or tech industry, decision-makers at VP level or above, US or EU based.\n\nScore this lead from 0 to 100 based on ICP fit. Respond ONLY in this exact JSON format, nothing else:\n{\n  \"score\": <number 0-100>,\n  \"grade\": \"<Hot/Warm/Cold>\",\n  \"reason\": \"<2 sentence explanation>\",\n  \"recommended_action\": \"<one of: Fast-track to demo / Standard sequence / Nurture only / Disqualify>\",\n  \"key_signal\": \"<the single most important thing about this lead>\"\n}",
              "role": "system"
            },
            {
              "content": "=Score this lead:\n\nName: {{ $json.name }}\nEmail: {{ $json.email }}\nJob Title: {{ $json.body.job_title }}\nCompany: {{ $json.body.company }}\nCompany Size: {{ $json.company_size }}\nIndustry: {{ $json.industry }}\n\nReturn only the JSON, no extra text."
            }
          ]
        },
        "options": {}
      },
      "id": "c94d38f4-6084-4b4d-b8dd-b835e23958c1",
      "name": "AI Lead Scoring",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1,
      "position": [
        448,
        112
      ],
      "credentials": {
        "openAiApi": {
          "id": "01zeIhp0RTXEhm8K",
          "name": "OpenAi account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.message.content;\nlet parsed;\ntry {\n  parsed = JSON.parse(raw);\n} catch(e) {\n  const match = raw.match(/\\{[\\s\\S]*\\}/);\n  parsed = match ? JSON.parse(match[0]) : { score: 50, grade: 'Warm', reason: 'Could not parse AI response.', recommended_action: 'Standard sequence', key_signal: 'N/A' };\n}\n\nconst enriched = $('Mock Enrichment Data').first()?.json || $('Format Apollo Data').first()?.json || {};\nconst intake = $('Lead Intake Webhook').first().json.body;\n\nreturn [{\n  json: {\n    name: enriched.name || intake.name,\n    email: enriched.email || intake.email,\n    job_title: enriched.job_title || intake.job_title,\n    company: enriched.company || intake.company,\n    company_size: enriched.company_size || '',\n    industry: enriched.industry || '',\n    location: enriched.location || '',\n    ai_score: parsed.score,\n    ai_grade: parsed.grade,\n    ai_reason: parsed.reason,\n    ai_action: parsed.recommended_action,\n    ai_signal: parsed.key_signal,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
      "id": "0dfbf1c9-8498-4af2-8a32-f8da0aa3e14f",
      "name": "Parse AI Score",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        800,
        112
      ]
    },
    {
      "parameters": {
        "select": "channel",
        "channelId": {
          "__rl": true,
          "value": "#crm-leads",
          "mode": "name"
        },
        "messageType": "block",
        "blocksUi": "={\n  \"blocks\": [\n    {\n      \"type\": \"section\",\n      \"text\": {\n        \"type\": \"mrkdwn\",\n        \"text\": \"*New Lead Requires Review*\\n\\n*Name:* {{ $json.name }}\\n*Email:* {{ $json.email }}\\n*Title:* {{ $json.job_title }}\\n*Company:* {{ $json.company }}\\n*Score:* {{ $json.ai_score }}/100 — {{ $json.ai_grade }}\\n*Recommended:* {{ $json.ai_action }}\\n*Reason:* {{ $json.ai_reason }}\"\n      }\n    },\n    {\n      \"type\": \"divider\"\n    },\n    {\n      \"type\": \"actions\",\n      \"elements\": [\n        {\n          \"type\": \"button\",\n          \"text\": { \"type\": \"plain_text\", \"text\": \"Approve\", \"emoji\": true },\n          \"style\": \"primary\",\n          \"value\": \"approve\",\n          \"action_id\": \"approve_lead\"\n        },\n        {\n          \"type\": \"button\",\n          \"text\": { \"type\": \"plain_text\", \"text\": \"Reject\", \"emoji\": true },\n          \"style\": \"danger\",\n          \"value\": \"reject\",\n          \"action_id\": \"reject_lead\"\n        }\n      ]\n    }\n  ]\n}",
        "text": "==New lead requires approval — {{ $json.name }}|{{ $json.email }}|{{ $json.job_title }}|{{ $json.company }}|{{ $json.industry }}|{{ $json.company_size }}|{{ $json.ai_score }}|{{ $json.ai_grade }}|{{ $json.ai_action }}|{{ $json.ai_reason }}|{{ $json.ai_signal }}",
        "otherOptions": {}
      },
